generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum ClienteStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PedidoStatus {
  PENDING
  CONFIRMED
  DOWNLOADED
  SHIPPED
}

enum ColorProducto {
  BLANCO
  CELESTE
  ROSA
  VERDE
  NEGRO
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(CLIENT)
  empresaId Int?
  empresa   Empresa?  @relation(fields: [empresaId], references: [id])
  cliente   Cliente?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("usuarios")
}

model Empresa {
  id            Int            @id @default(autoincrement())
  name          String
  usuarios      User[]
  clientes      Cliente[]
  productos     Producto[]
  categorias    Categoria[]
  subcategorias Subcategoria[]
  marcas        Marca[]
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("empresas")
}

model Cliente {
  id          Int           @id @default(autoincrement())
  razonSocial String
  titular     String
  cuit        String        @unique
  correo      String        @unique
  telefono    String
  status      ClienteStatus @default(PENDING)
  empresaId   Int
  empresa     Empresa       @relation(fields: [empresaId], references: [id])
  userId      String?       @unique
  user        User?         @relation(fields: [userId], references: [id])
  direcciones Address[]
  pedidos     Pedido[]
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("clientes")
}

model Address {
  id        Int       @id @default(autoincrement())
  provincia String
  localidad String
  direccion String
  codPostal String
  clienteId Int
  cliente   Cliente   @relation(fields: [clienteId], references: [id])
  pedidos   Pedido[]
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("direcciones")
}

model Categoria {
  id            Int            @id @default(autoincrement())
  name          String
  marcaId       Int
  marca         Marca          @relation(fields: [marcaId], references: [id])
  empresaId     Int
  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  subcategorias Subcategoria[]
  productos     Producto[]
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("categorias")
}

model Subcategoria {
  id          Int        @id @default(autoincrement())
  name        String
  categoriaId Int
  categoria   Categoria  @relation(fields: [categoriaId], references: [id])
  empresaId   Int
  empresa     Empresa    @relation(fields: [empresaId], references: [id])
  productos   Producto[]
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("subcategorias")
}

model Marca {
  id         Int         @id @default(autoincrement())
  name       String
  empresaId  Int
  empresa    Empresa     @relation(fields: [empresaId], references: [id])
  categorias Categoria[]
  productos  Producto[]
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("marcas")
}

model Producto {
  id             Int                @id @default(autoincrement())
  name           String
  sku            String             @unique
  price          Float
  imgUrl         String?
  sinStock       Boolean            @default(false)
  empresaId      Int
  empresa        Empresa            @relation(fields: [empresaId], references: [id])
  categoriaId    Int
  categoria      Categoria          @relation(fields: [categoriaId], references: [id])
  subcategoriaId Int?
  subcategoria   Subcategoria?      @relation(fields: [subcategoriaId], references: [id])
  marcaId        Int
  marca          Marca              @relation(fields: [marcaId], references: [id])
  variantes      ProductoVariante[]
  detallesPedido DetallePedido[]
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("productos")
}

model ProductoVariante {
  id         Int            @id @default(autoincrement())
  color      ColorProducto?
  talle      Int?
  sinStock   Boolean        @default(false)
  productoId Int
  producto   Producto       @relation(fields: [productoId], references: [id], onDelete: Cascade)
  deletedAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([productoId, color, talle])
  @@map("producto_variantes")
}

model Pedido {
  id             Int             @id @default(autoincrement())
  fecha          DateTime        @default(now())
  totalPedido    Float
  status         PedidoStatus    @default(PENDING)
  codSeguimiento String?
  clienteId      Int
  cliente        Cliente         @relation(fields: [clienteId], references: [id])
  direccionId    Int
  direccion      Address         @relation(fields: [direccionId], references: [id])
  detalles       DetallePedido[]
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("pedidos")
}

model DetallePedido {
  id         Int       @id @default(autoincrement())
  cantidad   Int
  total      Float
  pedidoId   Int
  pedido     Pedido    @relation(fields: [pedidoId], references: [id])
  productoId Int
  producto   Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("detalle_pedidos")
}
